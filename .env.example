# Copy to .env if you want docker compose variable substitution from a file.
# You do not need Python, pip, or Node on the host — only Docker.
# Build and run: docker compose up --build
#
# Behind HTTPS (reverse proxy): set COOKIE_SECURE=true so session cookies use the Secure flag.

ADMIN_API_KEY=generate-a-long-random-string
SESSION_SECRET=at-least-32-characters-long-secret-key
APP_ENCRYPTION_KEY=0123456789abcdef0123456789abcdef
ALLOWED_AREAS=orders,billing,webhooks

# Redis authentication password (used by both the Redis server and the app)
REDIS_PASSWORD=changeme

# Optional: require X-Bootstrap-Token on first admin registration
# BOOTSTRAP_TOKEN=

# Timezone for date display (default: UTC)
# Examples: Asia/Jerusalem, America/New_York, Europe/London
# TZ=UTC

# Token Validation Rate Limiting (per IP)
# RATE_LIMIT_MAX_REQ=120
# RATE_LIMIT_WINDOW_MS=60000
